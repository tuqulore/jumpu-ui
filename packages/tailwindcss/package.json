{
  "name": "@jumpu-ui/tailwindcss",
  "version": "3.0.0",
  "description": "A Tailwind CSS plugin of Jumpu UI implementation.",
  "keywords": [
    "tailwindcss"
  ],
  "homepage": "https://github.com/tuqulore/jumpu-ui#readme",
  "bugs": {
    "url": "https://github.com/tuqulore/jumpu-ui/issues"
  },
  "repository": "git@github.com:tuqulore/jumpu-ui.git",
  "license": "MIT",
  "author": "tuqulore inc.",
  "type": "module",
  "exports": {
    ".": "./src/style.css",
    "./*": "./src/*",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src",
    "NOTICE.md"
  ],
  "scripts": {
    "lint": "stylelint './**/*.css' --ignore-path .gitignore",
    "prepublishOnly": "npx @tailwindcss/cli -i ./dist.css -o ./dist/style.css"
  },
  "devDependencies": {
    "@tailwindcss/cli": "4.2.4",
    "@tailwindcss/typography": "0.5.19",
    "@tailwindcss/vite": "4.2.4",
    "stylelint": "17.11.0",
    "stylelint-config-recess-order": "7.7.0",
    "stylelint-config-standard": "40.0.0",
    "tailwindcss": "4.2.4",
    "vite": "8.0.10"
  },
  "peerDependencies": {
    "tailwindcss": "^4"
  },
  "publishConfig": {
    "access": "public"
  }
}
